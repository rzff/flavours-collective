{
  "manifest_version": 3,
  "name": "Product Scraper",
  "version": "1.0",
  "description": "Send current page URL to local scraping service",
  "permissions": ["activeTab"],
  "host_permissions": ["http://localhost:8080/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Scrape Products",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
